APP_NAME=AI.Sulu API
APP_ENV=development
API_V1_PREFIX=/api
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DATABASE_URL=sqlite:////app/app/data/ai_sulu.db

USE_MOCK_SERVICES=true
FALLBACK_MESSAGE=Я не уверена, пожалуйста, обратитесь к сотруднику университета.
FAQ_MATCH_THRESHOLD=0.42

OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

WHISPER_PROVIDER=mock
TTS_PROVIDER=mock
ELEVENLABS_API_KEY=
AZURE_TTS_KEY=
AZURE_TTS_REGION=
